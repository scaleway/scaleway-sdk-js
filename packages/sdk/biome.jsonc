{
  "$schema": "../../node_modules/@biomejs/biome/configuration_schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    },
   "enabled": true
  },
  "linter": {
    "rules": {
      "suspicious": {
        "noShadowRestrictedNames": "off"
      }
    }
  },
  "extends": "//",
  "root": false
}
