{
  "name": "@scaleway/sdk-react",
  "version": "0.2.0",
  "description": "React API Provider using client settings",
  "private": false,
  "sideEffects": false,
  "type": "module",
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/__generated__/api/*.d.ts",
      "default": "./dist/__generated__/api/*.js"
    }
  },
  "scripts": {
    "prebuild": "shx rm -rf dist && pnpm generate:api",
    "typecheck": "tsgo --noEmit",
    "generate:api": "pnpm generate-react-sdk --dir-gen-name src/__generated__/api  --sdk-factory-path '../../contexts/SDKCacheProvider/sdkFactory'",
    "format": "biome check  --linter-enabled=false --write .",
    "type:generate": "tsgo --declaration -p tsconfig.build.json",
    "build": "vite build --config vite.config.ts && pnpm run type:generate",
    "watch": "pnpm run '/^watch:.*/'",
    "lint": "biome lint ."
  },
  "peerDependencies": {
    "react": "18.x || 19.x"
  },
  "optionalDependencies": {
    "@scaleway/sdk-account": "workspace:*",
    "@scaleway/sdk-applesilicon": "workspace:*",
