{
  "name": "@scaleway/generate-react-queries",
  "version": "0.2.0",
  "description": "generate react api and queries",
  "type": "module",
  "private": false,
  "bin": {
    "generate-react-queries": "./dist/buildQueries.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.20.2"
  },
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "repository": {
    "type": "git",
    "directory": "tools/generate-react-queries"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "package:check": "pnpm publint",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "20.19.39",
    "ts-morph": "27.0.2"
  }
}
