{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rewriteRelativeImportExtensions": true,
    "noEmit": false,
    "declaration": true,
    "listEmittedFiles": false,
    "emitDeclarationOnly": false,
    "rootDir": "src",
    "outDir": "dist"
  },
  "exclude": [
    "dist/*",
    "*.config.ts",
    "*.setup.ts",
    "**/__tests__",
    "**/__mocks__",
    "src/**/*.test.tsx"
  ]
}
