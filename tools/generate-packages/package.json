{
  "name": "@scaleway/generate-packages",
  "version": "0.5.5",
  "private": false,
  "description": "Code generation scripts for Scaleway SDK packages",
  "repository": {
    "type": "git",
    "directory": "tools/generate-packages"
  },
  "bin": {
    "fix-import-extensions": "./src/fix-import-extensions.ts",
    "generateAlias": "./src/generateAlias.ts",
    "generatePackages": "./src/generatePackages.ts",
    "setupNewProducts": "./src/setupNewProducts.ts"
  },
  "files": [
    "dist",
    "templates"
  ],
  "type": "module",
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "package:check": "pnpm publint",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@repo/configs": "workspace:*",
    "@types/node": "20.19.43",
    "vite": "8.1.5"
  },
  "engines": {
    "node": ">=20.20.2"
  }
}
