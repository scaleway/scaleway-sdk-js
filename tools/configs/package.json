{
  "name": "@repo/configs",
  "version": "0.1.1",
  "private": true,
  "description": "handle configs",
  "repository": {
    "type": "git",
    "directory": "tools/configs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tsconfig/*": {
      "default": "./tsconfig/*.json"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "watch": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "20.19.43"
  },
  "engines": {
    "node": ">=20.20.2"
  }
}
