{
  "name": "root",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages_generated/*",
    "tools/*"
  ],
  "type": "module",
  "scripts": {
    "generateAlias": "generateAlias",
    "generatePackages": "generatePackages",
    "setupNewProducts": "setupNewProducts",
    "prebuild": "pnpm run generatePackages && pnpm run generateAlias && pnpm format",
    "build:packages": "pnpm turbo run build",
    "fix-import-extensions": "fix-import-extensions",
    "build": "pnpm run build:packages && pnpm run fix-import-extensions",
    "typecheck": "pnpm turbo typecheck",
    "build:profile": "cross-env PROFILE=true pnpm run build",
    "commit": "npx git-cz -a",
    "doc": "typedoc",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "biome lint .",
    "check": "biome check .",
    "prepare": "husky",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:junit": "vitest --reporter=junit --outputFile=test-report.junit.xml",
    "test:ui": "vitest --ui"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@manypkg/cli": "0.25.1",
    "@repo/configs": "workspace:^",
    "@scaleway/generate-packages": "workspace:*",
    "@scaleway/generate-react-sdk": "workspace:*",
    "@scaleway/tsconfig": "1.1.4",
    "@typescript/native-preview": "7.0.0-dev.20260420.1",
    "@vitest/coverage-istanbul": "3.2.4",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "3.2.4",
    "babel-plugin-annotate-pure-calls": "0.5.0",
    "browserslist": "4.28.1",
    "cross-env": "10.1.0",
    "cross-fetch": "4.1.0",
    "cz-conventional-changelog": "3.3.0",
    "esbuild-plugin-browserslist": "2.0.0",
    "husky": "9.1.7",
    "jsdom": "29.0.2",
    "lerna": "9.0.7",
    "lint-staged": "16.3.2",
    "oxfmt": "0.45.0",
    "react": "^19.2.5",
    "read-pkg": "10.1.0",
    "shx": "0.4.0",
    "tinyglobby": "0.2.16",
    "tsc-alias": "1.8.16",
    "turbo": "2.9.6",
    "typedoc": "0.28.17",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vitest": "3.2.4"
  },
  "lint-staged": {
    "packages/*/src/**/*.{ts,tsx,js,jsx}": [
      "pnpm run format"
    ],
    "tools/**/*.ts": [
      "pnpm run format"
    ],
    "*.y?(a)ml": [
      "pnpm oxfmt --write"
    ],
    "*.md?(x)": [
      "pnpm oxfmt --write"
    ],
    "*.json": [
      "pnpm run format"
    ],
    "(*package).json": [
      "pnpm exec manypkg check"
    ],
    "(*pnpm)-lock": [
      "pnpm exec manypkg check"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.30.3"
  },
  "packageManager": "pnpm@10.30.3"
}
